# Variables d'environnement pour Livret IB

# MongoDB (OBLIGATOIRE)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Livret2026
DB_NAME=teacherContributionsDB

# Templates Word depuis Google Docs (OPTIONNEL - valeurs par défaut dans le code)
# Si vous ne définissez pas ces variables, le code utilisera automatiquement l'URL Google Docs ci-dessous

# Template pour PEI (PEI1, PEI2, PEI3, PEI4, PEI5)
TEMPLATE_URL=https://docs.google.com/document/d/18eo_E2ex8K5xu5ce6BQhN8MWi5mL_Nga/export?format=docx

# Template pour DP (DP1, DP2)
TEMPLATE_URL_DP=https://docs.google.com/document/d/18eo_E2ex8K5xu5ce6BQhN8MWi5mL_Nga/export?format=docx

# Port (local uniquement)
PORT=3000

# IMPORTANT:
# Sur Vercel, configurez ces variables dans:
# Settings → Environment Variables
#
# ⚠️ NE PAS utiliser d'URL Glitch! Utilisez Google Docs uniquement.
# ⚠️ Si TEMPLATE_URL ou TEMPLATE_URL_DP pointent vers Glitch, supprimez-les de Vercel
#    Le code utilisera automatiquement Google Docs par défaut.
